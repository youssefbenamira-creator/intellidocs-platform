# Backend (NestJS) environment — copy to .env and fill in real values.
# When running via docker-compose these are provided by the compose file instead.

# PostgreSQL connection string
DATABASE_URL=postgresql://pfe_user:pfe_password@localhost:5435/pfe_db?schema=public

# JWT signing secrets (use long random strings in production)
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-too

# FastAPI AI microservice base URL
SCRAPER_URL=http://localhost:8001

# Shared key for service-to-service calls (scraper -> backend explorer sync)
INTERNAL_API_KEY=change-me-internal-key

# API port
PORT=3001
